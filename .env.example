# ===== CoolRoute env template =====
# Copy to ".env" and fill in. NEVER commit the real .env.

# --- Google Earth Engine (Landsat + MODIS) ---
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_PATH=
GEE_PROJECT_ID=enis-ee

# --- Data window (pilot: Kadikoy-Uskudar-Atasehir, summer + transition 2025) ---
DATA_START_DATE=2025-05-01
DATA_END_DATE=2025-10-31

# --- Simulation / reproducibility ---
RANDOM_SEED=42

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:8501"]
