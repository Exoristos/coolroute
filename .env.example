# ===== UHI-Battery env template =====
# Copy to ".env" and fill in. NEVER commit the real .env (already gitignored via .slim rule).

# --- Google Earth Engine (Landsat + MODIS) ---
# Create a service account + key from https://code.earthengine.google.com/
# Put the JSON key path here (absolute or repo-relative).
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_PATH=
# Or, if using application default credentials, leave both empty and run `gcloud auth application-default login`.
GEE_PROJECT_ID=

# --- Data window (pilot: Kadıköy corridor, summer + transition) ---
DATA_START_DATE=2024-06-01
DATA_END_DATE=2024-10-31

# --- Simulation / reproducibility ---
RANDOM_SEED=42

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:8501"]
